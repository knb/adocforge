{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@adocforge/core": ["packages/core/src/index.ts"],
      "@adocforge/ai": ["packages/ai/src/index.ts"],
      "@adocforge/editor": ["packages/editor/src/index.ts"],
      "@adocforge/editor/*": ["packages/editor/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts", "e2e/**/*.ts", "playwright.config.ts"]
}
