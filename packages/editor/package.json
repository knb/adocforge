{
  "name": "@adocforge/editor",
  "version": "0.0.0",
  "description": "Framework-independent AdocForge editor Web Component",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knb/adocforge.git",
    "directory": "packages/editor"
  },
  "homepage": "https://github.com/knb/adocforge#readme",
  "bugs": {
    "url": "https://github.com/knb/adocforge/issues"
  },
  "keywords": [
    "asciidoc",
    "editor",
    "web-component"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage/indexeddb": {
      "types": "./dist/storage/indexeddb.d.ts",
      "import": "./dist/storage/indexeddb.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/storage/indexeddb.ts --format esm --dts --clean --sourcemap --external lit --external codemirror --external @codemirror/state --external @codemirror/view --external @adocforge/ai --external @adocforge/core --external dompurify"
  },
  "dependencies": {
    "@adocforge/ai": "workspace:*",
    "@adocforge/core": "workspace:*",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.3",
    "lit": "^3.3.2",
    "lucide": "^1.25.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
