{
  "name": "@kbmemo/adoc-wysiwyg",
  "version": "0.1.0",
  "description": "Block-based AsciiDoc WYSIWYG editor built on CodeMirror 6.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./wysiwyg.css": "./dist/wysiwyg.css",
    "./contextMenu.css": "./dist/contextMenu.css"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://gitea.artif.org/Artif.org/kbmemo_site.git",
    "directory": "packages/adoc-wysiwyg"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup && cp wysiwyg.css contextMenu.css dist/",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@kbmemo/adoc-codemirror": "0.1.0",
    "@kbmemo/adoc-kbmemo": "0.1.0",
    "@kbmemo/adoc-preview": "0.1.0"
  },
  "peerDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0"
  }
}
