{
  "name": "@kbmemo/adoc-wysiwyg",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./wysiwyg.css": "./wysiwyg.css",
    "./contextMenu.css": "./contextMenu.css"
  },
  "publishConfig": {
    "access": "restricted",
    "exports": {
      ".": "./dist/index.js",
      "./wysiwyg.css": "./dist/wysiwyg.css",
      "./contextMenu.css": "./dist/contextMenu.css"
    }
  },
  "files": [
    "dist",
    "index.js",
    "*.js",
    "*.css"
  ],
  "scripts": {
    "build": "tsup && cp wysiwyg.css contextMenu.css dist/",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@kbmemo/adoc-codemirror": "*",
    "@kbmemo/adoc-kbmemo": "*",
    "@kbmemo/adoc-preview": "*"
  },
  "peerDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0"
  }
}
