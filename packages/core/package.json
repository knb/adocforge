{
  "name": "@adocforge/core",
  "version": "0.1.0",
  "description": "Framework-independent AsciiDoc processing contracts for AdocForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knb/adocforge.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/knb/adocforge#readme",
  "bugs": {
    "url": "https://github.com/knb/adocforge/issues"
  },
  "keywords": [
    "asciidoc",
    "asciidoctor"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --external @asciidoctor/core"
  },
  "dependencies": {
    "@asciidoctor/core": "^4.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
