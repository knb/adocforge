{
  "name": "@kbmemo/adoc-preview",
  "version": "0.1.0",
  "description": "Live AsciiDoc HTML preview for CodeMirror-based editors.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./preview_hljs.css": "./dist/preview_hljs.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knb/adocforge.git",
    "directory": "packages/adoc-preview"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup && cp preview_hljs.css dist/",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@kbmemo/adoc-codemirror": "0.1.0",
    "@kbmemo/adoc-kbmemo": "0.1.0"
  },
  "peerDependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.11"
  },
  "homepage": "https://github.com/knb/adocforge#readme",
  "bugs": {
    "url": "https://github.com/knb/adocforge/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
