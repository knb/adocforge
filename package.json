{
  "name": "kbmemo-asciidoc-editor-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:packages",
    "test": "vitest run",
    "pack:packages": "npm run build && node scripts/verify-package-tarballs.mjs",
    "report:syntax-coverage": "node scripts/report-syntax-coverage.mjs",
    "verify:consumer": "node scripts/verify-consumer-install.mjs",
    "verify:publish": "node scripts/verify-publish-readiness.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "pretest": "npm run build",
    "build:packages": "npm run build --workspace @kbmemo/adoc-kbmemo --workspace @kbmemo/adoc-codemirror --workspace @kbmemo/adoc-preview --workspace @kbmemo/adoc-wysiwyg --workspace @kbmemo/adoc-editor",
    "build:demo": "npm run build --workspace adoc-editor-demo"
  },
  "dependencies": {
    "@asciidoctor/core": "^4.0.4",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.11"
  },
  "devDependencies": {
    "happy-dom": "^20.9.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}
