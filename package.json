{
  "name": "adocforge-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm run build:current && pnpm run build:playground && pnpm run build:legacy",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project tsconfig.base.json",
    "test:e2e": "playwright test",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "pack:packages": "pnpm run build && node scripts/verify-package-tarballs.mjs",
    "report:syntax-coverage": "node scripts/report-syntax-coverage.mjs",
    "verify:consumer": "node scripts/verify-consumer-install.mjs",
    "verify:publish": "node scripts/verify-publish-readiness.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "pretest": "pnpm run build",
    "build:current": "pnpm --filter './packages/*' run build",
    "build:playground": "pnpm --filter @adocforge/playground run build",
    "build:legacy": "pnpm --filter './legacy/packages/*' run --if-present build",
    "build:packages": "pnpm run build:current",
    "build:demo": "pnpm --filter adoc-editor-demo run build"
  },
  "dependencies": {
    "@asciidoctor/core": "^4.0.4",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}
